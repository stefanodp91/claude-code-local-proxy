{
  "name": "anthropic-openai-proxy",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "start": "node --import tsx src/main.ts",
    "dev": "tsx --watch src/main.ts",
    "build": "tsup src/main.ts --format esm --target node18 --outDir dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
